{
	"name": "noblesse-property",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"start": "node build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"db:test": "node --env-file=.env db/test-connection.mjs",
		"db:seed": "node --env-file=.env db/seed.mjs",
		"db:create-admin": "node --env-file=.env db/create-admin.mjs",
		"db:studio": "drizzle-kit studio",
		"db:pull": "drizzle-kit pull"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-node": "^5.5.6",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.1",
		"@types/qrcode": "^1.5.6",
		"dotenv": "^17.4.2",
		"drizzle-kit": "^0.31.10",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.1",
		"typescript": "^6.0.3",
		"vite": "^8.0.16"
	},
	"dependencies": {
		"@node-rs/argon2": "^2.0.2",
		"drizzle-orm": "^0.45.2",
		"mysql2": "^3.22.5",
		"qrcode": "^1.5.4",
		"sharp": "^0.35.3"
	}
}
